    "test:neck-levels": "node tools/test_neck_levels.mjs",
    "test:gpu-staged-profile": "node tools/test_gpu_staged_profile.mjs",
    "test:webgpu-route-receipt": "node tools/test_webgpu_route_receipt.mjs",
    "test:route-boundary": "node tools/test_route_boundary_contracts.mjs",
    "test:route-schema-contract": "node tools/test_route_schema_contract.mjs",
    "test:gpu-timestamps": "node tools/test_gpu_timestamps.mjs",
    "test:phase-timings": "node tools/test_phase_timings.mjs",
