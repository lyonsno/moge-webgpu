    "dev": "vite",
    "build": "vite build",
    "benchmark:ab": "node tools/benchmark_ab.mjs",
    "test:decoder-substages": "node tools/test_decoder_substages.mjs",
    "test:neck-internals": "node tools/test_neck_internals.mjs",
    "test:neck-resampler": "node tools/test_neck_resampler.mjs",
